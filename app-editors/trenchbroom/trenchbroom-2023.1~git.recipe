SUMMARY="Cross-Platform Level Editor "
DESCRIPTION="TrenchBroom is a free (GPLv3+), cross platform level editor for Quake-engine \
based games. It supports Quake, Quake 2, and Hexen 2 and runs on Windows (XP and newer), \
Mac OS X (10.6 and newer) and Linux. TrenchBroom is easy to use and provides many simple \
and advanced tools to create complex and interesting levels with ease."
HOMEPAGE="https://trenchbroom.github.io/"
COPYRIGHT="2010-2023 Kristian Duske"
LICENSE="GNU GPL v3"
REVISION="1"
srcGitRev="5ffdbbc97dc478532637be7e1457ba7b08a2803f"
SOURCE_URI="https://github.com/TrenchBroom/TrenchBroom/archive/$srcGitRev.tar.gz"
CHECKSUM_SHA256="dc7f4a4e49c408bd0ff80926f90dca2c8359bf51bf5fd9bb972c0f8390772b55"
SOURCE_DIR="TrenchBroom-$portVersion"
PATCHES="trenchbroom-$portVersion.patchset"
ADDITIONAL_FILES="FindFreeImage.cmake"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

PROVIDES="
	trenchbroom$secondaryArchSuffix = $portVersion
	app:TrenchBroom
	"
REQUIRES="
	haiku$secondaryArchSuffix
	lib:libqt5$secondaryArchSuffix
	lib:libfreetype$secondaryArchSuffix
	lib:libfreeimage$secondaryArchSuffix
	lib:libglew$secondaryArchSuffix
	lib:libtinyxml$secondaryArchSuffix
	lib:libminiz$secondaryArchSuffix
	lib:libassimp$secondaryArchSuffix
	lib:libcatch2$secondaryArchSuffix
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	devel:libqt5$secondaryArchSuffix
	devel:libfreetype$secondaryArchSuffix
	devel:libfreeimage$secondaryArchSuffix
	devel:libglew$secondaryArchSuffix
	devel:libtinyxml$secondaryArchSuffix
	devel:libminiz$secondaryArchSuffix
	devel:libassimp$secondaryArchSuffix
	devel:libcatch2$secondaryArchSuffix
	"
BUILD_PREREQUIRES="
	cmd:gcc$secondaryArchSuffix
	cmd:ld$secondaryArchSuffix
	cmd:make
	cmd:cmake
	"

BUILD()
{
	# copy FindFreeImage.cmake
	cp -a $portDir/additional-files/FindFreeImage.cmake $sourceDir/cmake

	# build
	mkdir -p $sourceDir/cmake-build-haiku
	cd -a $sourceDir/cmake-build-haiku
	cmake ..
	make
}

INSTALL()
{
	mkdir -p $appsDir
	cp -a $sourceDir/cmake-build-haiku/TrenchBroom $appsDir/TrenchBroom

	addAppDeskbarSymlink $appsDir/QuakeSpasm
}
