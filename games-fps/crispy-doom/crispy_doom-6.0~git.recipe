SUMMARY="A limit-removing enhanced-resolution Doom source port based on Chocolate Doom"
DESCRIPTION="Crispy Doom is a friendly fork of Chocolate Doom that provides a higher display \
resolution, removes the static limits of the Doom engine and offers further optional visual, \
tactical and physical enhancements while remaining entirely config file, savegame, netplay \
and demo compatible with the original."
HOMEPAGE="https://github.com/fabiangreffrath/crispy-doom"
COPYRIGHT="2014-2019 Fabian Greffrath"
LICENSE="GNU GPL v2"
REVISION="1"
srcGitRev="e69e50c9cd6dccc245bbe8252dae3ebac013b876"
SOURCE_URI="https://github.com/fabiangreffrath/crispy-doom/archive/$srcGitRev.tar.gz"
CHECKSUM_SHA256="8020aa18b12c2deaddb266a6e1b69d99951b21dc98f32f887e3709b63ccd0c68"
SOURCE_DIR="crispy-doom-$srcGitRev"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

PROVIDES="
	crispy_doom$secondaryArchSuffix = $portVersion
	cmd:crispy_doom = $portVersion
	cmd:crispy_doom_setup = $portVersion
	cmd:crispy_heretic = $portVersion
	cmd:crispy_heretic_setup = $portVersion
	cmd:crispy_hexen = $portVersion
	cmd:crispy_hexen_setup = $portVersion
	cmd:crispy_server = $portVersion
	cmd:crispy_setup = $portVersion
	cmd:crispy_strife = $portVersion
	cmd:crispy_strife_setup = $portVersion
	"
REQUIRES="
	haiku$secondaryArchSuffix
	lib:libsdl2_2.0$secondaryArchSuffix
	lib:libsdl2_net_2.0$secondaryArchSuffix
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	devel:libsdl2_2.0$secondaryArchSuffix
	devel:libsdl2_net_2.0$secondaryArchSuffix
	"
BUILD_PREREQUIRES="
	cmd:gcc$secondaryArchSuffix
	cmd:ld$secondaryArchSuffix
	cmd:autoreconf$secondaryArchSuffix
	cmd:aclocal$secondaryArchSuffix
	cmd:make$secondaryArchSuffix
	cmd:pkg_config$secondaryArchSuffix
	"

BUILD()
{
	autoreconf -fiv
	runConfigure ./configure
	make $jobArgs
}

INSTALL()
{
	make install install-exec
}
